.root{
  max-width: 1440px;
  min-height: 100vh;
  height: 1px;
  margin: auto;
  line-height: normal;
  color: #FFFFFF;
  flex-direction: column;
  background-color: rgb(123, 220, 220);
}

.pages-nav{
  position: fixed;
  display: flex;
  align-items: center;
  top: 0;
  left: 0;
  background-color: #FF0000;
  width: 100%;
  height: 32px;
}

.chat{
  width: 100%;
  height: 100vh;
  background-color: blueviolet;
}
