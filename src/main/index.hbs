---
id: "root" 
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Massenger</title>
  <link rel="stylesheet" href="../pages/index.pcss" />
</head>
<body>
  <div class="root">
    <header class="pages-nav">
      <a class="button-nav" href="../pages/sign-in/signin.hbs">{{> button/button label = 'Вход'}}</a>
      <a class="button-nav" href="../pages/sign-up/signup.hbs">{{> button/button label = 'Регистрация'}}</a>
    </header>
    <div class="chat">
      <div class="chat__left">
        <div class="chat__search-block">
          <p class="chat__profile">Профиль ></p>
          <input type="search" id="search-chat" name="search" class="chat__search" placeholder="Поиск" value="">
        </div>
        <div class="chat__list">
          {{> chat/chat  userName = 'Гутенберг' lastMessage ='Привет, дружище' dateTime = 'Вт' unredAmount = 3 }}
          {{> chat/chat  contentClass = "content-holder__choice" userName = 'Аня' lastMessage ='Привет, дружище' dateTime = 'Вт' unredAmount = 3 }}

        </div>
      </div>
      <div class="chat-right"></div>
    </div>
  </div>
</body>
</html>
